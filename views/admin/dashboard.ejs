<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="flash-container">
    <% if (error.length > 0) { %>
        <div class="alert alert-error">⚠️ <%= error %></div>
    <% } %>
    <% if (success.length > 0) { %>
        <div class="alert alert-success">✅ <%= success %></div>
    <% } %>
</div>

<div class="admin-page">
    <div class="welcome-banner">
        <div>
            <h3>Admin Dashboard 🛠️</h3>
            <p>Manage your restaurant from here</p>
        </div>
        <div class="banner-icon">
            <i class="fa-solid fa-gauge"></i>
        </div>
    </div>

    <div class="dashboard-grid">
        <div class="dashboard-card">
            <i class="fa-solid fa-bowl-food card-icon"></i>
            <h5>Menu Items</h5>
            <p><%= stats.totalItems %> items</p>
            <a href="/admin/menu">Manage</a>
        </div>
        <div class="dashboard-card">
            <i class="fa-solid fa-users card-icon"></i>
            <h5>Users</h5>
            <p><%= stats.totalUsers %> registered</p>
            <a href="/admin/users">View All</a>
        </div>
        <div class="dashboard-card">
            <i class="fa-solid fa-calendar-days card-icon"></i>
            <h5>Reservations</h5>
            <p><%= stats.totalReservations %> bookings</p>
            <a href="/admin/reservations">View All</a>
        </div>
        <div class="dashboard-card">
            <i class="fa-solid fa-bag-shopping card-icon"></i>
            <h5>Orders</h5>
            <p><%= stats.totalOrders %> orders</p>
            <a href="/admin">View</a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>

<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="flash-container">
    <% if (error.length > 0) { %>
        <div class="alert alert-error">⚠️ <%= error %></div>
    <% } %>
</div>

<div class="reservation-page">
    <div class="reservation-card">
        <div class="reservation-header">
            <h2><%= item ? 'Edit Item' : 'Add New Item' %></h2>
            <p><%= item ? 'Update the menu item details below' : 'Fill in the details to add a new item' %></p>
        </div>

        <form action="<%= item ? `/admin/menu/${item._id}/edit` : '/admin/menu/add' %>" method="POST" class="reservation-form">

            <div class="form-group">
                <label for="name">Item Name</label>
                <input type="text" id="name" name="name" value="<%= item ? item.name : '' %>" required>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3"><%= item ? item.description : '' %></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="price">Price (₹)</label>
                    <input type="number" id="price" name="price" value="<%= item ? item.price : '' %>" min="1" required>
                </div>
                <div class="form-group">
                    <label for="category">Category</label>
                    <select id="category" name="category" required>
                        <% ['Gujarati','Starters','Main Course','Breads','Rice','Desserts','Drinks'].forEach(cat => { %>
                            <option value="<%= cat %>" <%= item && item.category === cat ? 'selected' : '' %>><%= cat %></option>
                        <% }) %>
                    </select>
                </div>
            </div>

            <div class="form-group" style="display:flex; align-items:center; gap:0.6rem;">
                <input type="checkbox" id="isAvailable" name="isAvailable" style="width:auto;"
                    <%= !item || item.isAvailable ? 'checked' : '' %>>
                <label for="isAvailable" style="margin:0;">Available on menu</label>
            </div>

            <button type="submit" class="btn-hero btn-hero-primary" style="width:100%; justify-content:center; margin-top:0.5rem;">
                <i class="fa-solid fa-<%= item ? 'pen' : 'plus' %>"></i>
                <%= item ? 'Update Item' : 'Add Item' %>
            </button>
        </form>

        <a href="/admin/menu" class="back-link" style="display:block; text-align:center; margin-top:1.2rem;">← Back to Menu List</a>
    </div>
</div>

<%- include('../../partials/footer') %>
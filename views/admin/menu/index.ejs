<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="flash-container">
    <% if (error.length > 0) { %>
        <div class="alert alert-error">⚠️ <%= error %></div>
    <% } %>
    <% if (success.length > 0) { %>
        <div class="alert alert-success">✅ <%= success %></div>
    <% } %>
</div>

<div class="admin-page">
    <div class="admin-header">
        <h2>Manage Menu</h2>
        <a href="/admin/menu/add" class="btn-hero btn-hero-primary">
            <i class="fa-solid fa-plus"></i> Add New Item
        </a>
    </div>

    <% if (menuItems.length === 0) { %>
        <p style="text-align:center; color:#888; margin-top:2rem;">No menu items yet.</p>
    <% } else { %>
        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Available</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% menuItems.forEach(item => { %>
                        <tr>
                            <td><strong><%= item.name %></strong></td>
                            <td><span class="menu-category-tag"><%= item.category %></span></td>
                            <td>₹<%= item.price %></td>
                            <td>
                                <span class="status-badge <%= item.isAvailable ? 'status-confirmed' : 'status-cancelled' %>">
                                    <%= item.isAvailable ? 'Yes' : 'No' %>
                                </span>
                            </td>
                            <td class="admin-actions">
                                <a href="/admin/menu/<%= item._id %>/edit" class="btn-edit">Edit</a>
                                <form action="/admin/menu/<%= item._id %>/delete" method="POST" style="display:inline;">
                                    <button type="submit" class="btn-cancel" onclick="return confirm('Delete <%= item.name %>?')">Delete</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>

    <a href="/dashboard" class="back-link" style="display:block; text-align:center; margin-top:1.5rem;">← Back to Dashboard</a>
</div>

<%- include('../../partials/footer') %>
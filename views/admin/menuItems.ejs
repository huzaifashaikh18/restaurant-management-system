<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="flash-container">
    <% if (error.length > 0) { %>
        <div class="alert alert-error">⚠️ <%= error %></div>
    <% } %>
    <% if (success.length > 0) { %>
        <div class="alert alert-success">✅ <%= success %></div>
    <% } %>
</div>

<div class="admin-page">
    <div class="admin-header">
        <h2>Manage Menu Items</h2>
        <a href="/admin/menu/new" class="btn-primary" style="width:auto; padding:0.7rem 1.5rem;">+ Add New Item</a>
    </div>

    <div class="admin-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Available</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% menuItems.forEach(item => { %>
                    <tr>
                        <td>
                            <img src="<%= item.image %>" alt="<%= item.name %>"
                                 style="width:60px; height:60px; object-fit:cover; border-radius:8px;">
                        </td>
                        <td><strong><%= item.name %></strong></td>
                        <td><span class="menu-category-tag"><%= item.category %></span></td>
                        <td>₹<%= item.price %></td>
                        <td>
                            <span class="status-badge <%= item.isAvailable ? 'status-confirmed' : 'status-cancelled' %>">
                                <%= item.isAvailable ? 'Yes' : 'No' %>
                            </span>
                        </td>
                        <td>
                            <div class="admin-actions">
                                <a href="/admin/menu/<%= item._id %>/edit" class="btn-edit">Edit</a>
                                <form action="/admin/menu/<%= item._id %>?_method=DELETE" method="POST" style="display:inline;">
                                    <button type="submit" class="btn-cancel" onclick="return confirm('Delete this item?')">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>

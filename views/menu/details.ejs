<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="item-details-page">
    <div class="item-details-card">
        <div class="item-details-img">
            <% if (item.image && !item.image.includes('default')) { %>
                <img src="<%= item.image %>" alt="<%= item.name %>"
                     style="width:100%; height:100%; object-fit:cover;">
            <% } else { %>
                <i class="fa-solid fa-bowl-food"></i>
            <% } %>
        </div>
        <div class="item-details-body">
            <span class="menu-category-tag"><%= item.category %></span>
            <h2><%= item.name %></h2>
            <p class="item-description"><%= item.description %></p>
            <div class="item-price">₹<%= item.price %></div>

            <% if (user) { %>
                <form action="/orders" method="POST" style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 10px;">
                    <input type="hidden" name="menuItemId" value="<%= item._id %>">
                    
                    <div style="display: flex; gap: 10px; align-items: center;">
                        <label for="quantity" style="color: #ccc;">Qty:</label>
                        <input type="number" name="quantity" id="quantity" value="1" min="1" max="20" style="width: 70px; padding: 8px; border-radius: 6px; border: 1px solid #444; background-color: #222; color: #fff;">
                        
                        <select name="paymentMethod" style="flex: 1; padding: 8px; border-radius: 6px; border: 1px solid #444; background-color: #222; color: #fff;">
                            <option value="Cash">Cash</option>
                            <option value="Card">Card</option>
                            <option value="UPI">UPI</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn-primary" style="width: 100%; border: none; cursor: pointer; padding: 12px; font-weight: bold;">
                        <i class="fa-solid fa-cart-shopping"></i> Order Now
                    </button>
                </form>
                
                <a href="/reservations" class="btn-primary" 
                   style="display:block; text-align:center; margin-top:10px; background: transparent; border: 1px solid #f0a500; color: #f0a500;">
                   Book a Table
                </a>
            <% } else { %>
                <a href="/login" class="btn-primary" 
                   style="display:block; text-align:center; margin-top:1rem;">
                   Login to Order
                </a>
            <% } %>

            <a href="/menu" class="back-link">← Back to Menu</a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
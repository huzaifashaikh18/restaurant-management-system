<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="item-details-page">
    <div class="item-details-card">
        <div class="item-details-img">
            <% if (item.image && !item.image.includes('default')) { %>
                <img src="<%= item.image %>" alt="<%= item.name %>"
                     style="width:100%; height:100%; object-fit:cover;">
            <% } else { %>
                <i class="fa-solid fa-bowl-food"></i>
            <% } %>
        </div>
        <div class="item-details-body">
            <span class="menu-category-tag"><%= item.category %></span>
            <h2><%= item.name %></h2>
            <p class="item-description"><%= item.description %></p>
            <div class="item-price">₹<%= item.price %></div>

            <% if (user) { %>
                <a href="/reservations" class="btn-primary" 
                   style="display:block; text-align:center; margin-top:1rem;">
                   Book a Table
                </a>
            <% } else { %>
                <a href="/login" class="btn-primary" 
                   style="display:block; text-align:center; margin-top:1rem;">
                   Login to Order
                </a>
            <% } %>

            <a href="/menu" class="back-link">← Back to Menu</a>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
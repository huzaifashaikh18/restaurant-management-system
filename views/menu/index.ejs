<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="menu-page">
    <div class="menu-header">
        <h2>Our Menu</h2>
        <p>Authentic Gujarati & Indian flavors, made fresh every day</p>
    </div>

    <!-- Category Filter -->
    <div class="category-filter">
        <a href="/menu" class="category-btn <%= activeCategory === 'All' ? 'active' : '' %>">All</a>
        <% categories.forEach(cat => { %>
            <a href="/menu?category=<%= encodeURIComponent(cat) %>" 
                class="category-btn <%= activeCategory === cat ? 'active' : '' %>">
                <%= cat %>
            </a>
            <% }) %>
    </div>

    <!-- Menu Grid -->
    <% if (menuItems.length === 0) { %>
        <p style="text-align:center; color:#888; margin-top:3rem;">No items found.</p>
    <% } else { %>
        <div class="menu-grid">
            <% menuItems.forEach(item => { %>
                <a href="/menu/<%= item._id %>" class="menu-card">
                    <div class="menu-card-img">
                        <% if (item.image && !item.image.includes('default')) { %>
                            <img src="<%= item.image %>" alt="<%= item.name %>" 
                                 style="width:100%; height:100%; object-fit:cover;">
                        <% } else { %>
                            <i class="fa-solid fa-bowl-food"></i>
                        <% } %>
                    </div>
                    <div class="menu-card-body">
                        <span class="menu-category-tag"><%= item.category %></span>
                        <h5><%= item.name %></h5>
                        <p><%= item.description %></p>
                        <div class="menu-price">₹<%= item.price %></div>
                    </div>
                </a>
            <% }) %>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>
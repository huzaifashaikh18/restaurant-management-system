<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="flash-container">
    <% if (error.length > 0) { %>
        <div class="alert alert-error" style="margin-top:1rem;">⚠️ <%= error %></div>
    <% } %>
</div>

<div class="menu-page">

    <div class="menu-header">
        <h2>Our Menu</h2>
        <p>Authentic Gujarati & Indian flavors, made fresh every day</p>
    </div>

    <!-- Category Filter -->
    <div class="category-filter">
        <a href="/menu" class="category-btn <%= activeCategory === 'All' ? 'active' : '' %>">All</a>
        <% categories.forEach(cat => { %>
            <a href="/menu?category=<%= cat %>" class="category-btn <%= activeCategory === cat ? 'active' : '' %>"><%= cat %></a>
        <% }) %>
    </div>

    <!-- Menu Grid -->
    <% if (menuItems.length === 0) { %>
        <p style="text-align:center; color:#888; margin-top:3rem;">No items found in this category.</p>
    <% } else { %>
        <div class="menu-grid">
            <% menuItems.forEach(item => { %>
                <a href="/menu/<%= item._id %>" class="menu-card">
                    <div class="menu-card-img">
                        <i class="fa-solid fa-bowl-food"></i>
                    </div>
                    <div class="menu-card-body">
                        <span class="menu-category-tag"><%= item.category %></span>
                        <h5><%= item.name %></h5>
                        <p><%= item.description %></p>
                        <div class="menu-price">₹<%= item.price %></div>
                    </div>
                </a>
            <% }) %>
        </div>
    <% } %>

</div>

<%- include('../partials/footer') %>